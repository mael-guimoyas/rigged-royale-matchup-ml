{
  "nodes": [
    {"id":"readme_pipeline","label":"Matchup ML Pipeline","file_type":"concept","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\README.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Estimates intrinsic matchup quality from real win/loss without modeling individual player skill; interactions/synergies are learned, not hardcoded."},
    {"id":"readme_antisymmetric_architecture","label":"Antisymmetric Architecture P(A>B)=1-P(B>A)","file_type":"rationale","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\README.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Guarantees self-consistent probabilities so swapping team/opponent inverts the prediction; raw model logit stays antisymmetric even after calibration."},
    {"id":"readme_matrix_prior","label":"Empirical Matrix Prior","file_type":"rationale","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\README.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Existing empirical matrix used only as a prior, never the main target; the network learns a residual around it and can exceed it. Disabled by default (strength 0.0). Must not be built on validation/test data."},
    {"id":"readme_bilinear_cross","label":"Bilinear Oriented Card-vs-Card Interaction","file_type":"rationale","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\README.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"(A·W)⊙B learned matrix encodes oriented 'A counters B' instead of a symmetric Hadamard product; initialised to identity, learns counter structure from win/loss only."},
    {"id":"readme_noise_floor","label":"Irreducible Brier Noise Floor","file_type":"rationale","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\README.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"With binary win/loss labels and true matchup rate p, best possible per-game Brier is p*(1-p); model_brier_gap_to_floor tells whether to invest in architecture vs more data/coverage."},
    {"id":"readme_calibration","label":"Per-Segment Affine Calibration","file_type":"concept","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\README.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"logit/temperature + bias learned on validation, globally then per segment; segments below segment_calibration_min_rows fall back to global."},
    {"id":"readme_chronological_split","label":"Chronological 70/15/15 Split","file_type":"rationale","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\README.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Time-ordered, never random, with a fully separate future test set so calibration is judged on a future period."},
    {"id":"readme_deduplication","label":"Cross-Player Battle Deduplication","file_type":"concept","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\README.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Same battle seen from two players counted once via canonical game_id, tracked in data/dedup.sqlite3."},
    {"id":"readme_balanced_collection","label":"Trophy-Band Balanced Collection","file_type":"rationale","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\README.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Targets under-represented trophy bands; drops sub-5000 ladder opponents to avoid bloating the crawl frontier; ranked battles always queued. --no-balance reverts to FIFO crawl."},
    {"id":"readme_card2vec_init","label":"card2vec Embedding Warm-Start","file_type":"rationale","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\README.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Self-supervised deck co-occurrence pretraining so rare cards start near functionally-similar ones instead of random; no labels, no card stats."},
    {"id":"readme_segment_adapters","label":"Per-Segment Meta Adapters","file_type":"concept","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\README.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Adapters modulate card interactions by meta context (mode/patch/arena/ladder/ranked-league segment)."},
    {"id":"readme_matchup_model","label":"Trained Matchup Model Checkpoint (artifacts/matchup-model.pt)","file_type":"concept","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\README.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Calibrated checkpoint written by train; embeds data_config (trophy buckets) so segment resolution is self-describing."},
    {"id":"readme_collect_api_command","label":"collect-api CLI Command","file_type":"concept","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\README.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Collects battlelogs directly from the CR API into Parquet shards (local + Supabase Storage), snowballing opponents; needs a seed (--from-supabase or --tags-file)."},
    {"id":"readme_attach_prior","label":"attach-prior CLI Command","file_type":"concept","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\README.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Reuses the live app matrix rules to rebuild the empirical matrix on the train period only, then replaces matrix_prior in the splits."},
    {"id":"readme_train_command","label":"train CLI Command","file_type":"concept","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\README.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Warmup+cosine LR, label smoothing, card_dropout, gradient accumulation; writes the calibrated checkpoint and auto-uses CUDA if available."},
    {"id":"readme_benchmark_command","label":"benchmark CLI Command","file_type":"concept","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\README.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Compares model against constant_0.5, matrix_prior, and the irreducible noise floor on the same split."},
    {"id":"readme_predict_command","label":"predict CLI / Inference","file_type":"concept","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\README.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Infers a single matchup; card identity is the primary variable so a new hero is supported once its ID appears in training data (roles: 1=normal,2=champion,3=hero)."},
    {"id":"readme_empirical_prior","label":"Train-Only Empirical Prior Module","file_type":"concept","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\README.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"empirical_prior.py builds a train-only prior plus per-segment diagnostics; prior-metrics.json reports prior-alone metrics and coverage."},
    {"id":"config_default","label":"Default Pipeline Config (config/default.yaml)","file_type":"code","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\config\\default.yaml","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},
    {"id":"config_default_matrix_prior_strength","label":"matrix_prior_strength Config Key","file_type":"code","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\config\\default.yaml","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"0.0 ignores the prior entirely; with a constant 0.5 prior it has no effect. Needs attach-prior then learnable or fixed >0 to actually use a matrix prior."},
    {"id":"config_default_trophy_buckets","label":"trophy_buckets Config Key","file_type":"code","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\config\\default.yaml","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"14000 split added to break the old 12000+ blob into 12000-13999 + 14000+ for the seasonal trophy road."},
    {"id":"config_default_collect_min_trophies","label":"collect_min_trophies Config Key","file_type":"code","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\config\\default.yaml","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"collect-api drops ladder battles/opponents below this (5000); avoids training on sub-5000 ladder and bloating the frontier."},
    {"id":"config_default_empirical_app_dir","label":"empirical_app_dir Config Key (../riggedroyale)","file_type":"code","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\config\\default.yaml","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Points attach-prior at the live app repo to reuse empirical matchup classification rules instead of duplicating them in Python."},
    {"id":"config_default_use_bilinear_cross","label":"use_bilinear_cross Config Key","file_type":"code","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\config\\default.yaml","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},
    {"id":"config_default_card2vec_init","label":"card2vec_init Config Key","file_type":"code","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\config\\default.yaml","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},
    {"id":"cloud_run_deploy","label":"Cloud Run Deployment","file_type":"concept","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\CLOUD_RUN.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Checkpoint baked into the image because Cloud Run has no writable volume mounts; updating the model means rebuild + redeploy. --min-instances 1 avoids cold-start checkpoint load."},
    {"id":"cloud_run_inference_server","label":"Stateless FastAPI Inference Server (POST /predict, GET /health)","file_type":"concept","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\CLOUD_RUN.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},
    {"id":"cloud_run_predict_api_key","label":"PREDICT_API_KEY (X-API-Key gate)","file_type":"concept","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\CLOUD_RUN.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Optional shared secret so only the Vercel site can call /predict; same value must be set in Vercel."},
    {"id":"docker_compose_inference_service","label":"Local-Dev Inference Service (docker-compose)","file_type":"code","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\docker-compose.yml","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Mounts artifacts/matchup-model.pt read-only so rebuilds aren't needed to swap models; MODEL_NAME=symmetric-matchup on port 8080."},
    {"id":"runpod_training_run","label":"RunPod Single-GPU Training","file_type":"document","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\RUNPOD_TRAINING.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Trainer uses one CUDA device (no DDP/DataParallel), so multi-GPU is wasted; scripts/runpod_train.sh pulls Storage, prepare, pretrain-cards, train, evaluate, benchmark."},
    {"id":"seeds_tags","label":"Player Tag Seed List (seeds.txt)","file_type":"document","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\seeds.txt","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Newline-delimited Clash Royale player tags used as the --tags-file seed for collect-api snowball crawling."},
    {"id":"riggedroyale_app","label":"Rigged Royale Web App (consumer site)","file_type":"concept","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\.playwright-mcp\\page-2026-06-22T10-01-25-258Z.yml","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Vercel-hosted front end that calls the Cloud Run inference server via ML_INFERENCE_URL and falls back to the empirical matrix per battle when a prediction is missing."},
    {"id":"board_public_case_board","label":"Public Case Board (Most/Least Rigged Rankings)","file_type":"document","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\.playwright-mcp\\page-2026-06-22T10-01-25-258Z.yml","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Ranks public players by ranked/ladder verdict; requires >=8 usable 1v1 battles; uses up to the newest 200 per report."},
    {"id":"report_rigged_score","label":"Player Rigged-Score Report","file_type":"document","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\.playwright-mcp\\page-2026-06-22T10-02-07-706Z.yml","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Observational anomaly score from three evidence-weighted checks (Matchup Draw 60%, Timing Pressure 29%, Card Levels 11%); not proof matchmaking selected opponents."},
    {"id":"report_matchup_win_chance","label":"Per-Battle Win Chance & Matchup Labels UI","file_type":"document","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\.playwright-mcp\\page-2026-06-22T10-02-07-706Z.yml","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Battle audit shows deck-vs-deck win chance and BAD/EVEN/FAVORED labels with counter explanations ('their X shuts down your Y')."},
    {"id":"report_skill_rating","label":"Skill Rating — Pilot vs Deck","file_type":"document","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\.playwright-mcp\\page-2026-06-22T10-02-07-706Z.yml","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Compares actual wins vs the matchup/level/trophy model's expected wins (with 95% CI) as a proxy for piloting, separate from the rigged score."},
    {"id":"report_fallback_shell_prior","label":"Fallback Shell Prior (UI mention)","file_type":"document","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\.playwright-mcp\\page-2026-06-22T10-05-05-985Z.yml","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"When the model lacks a specific pairing, the UI explains the win chance came from a fallback shell prior leaning for/against the pairing."},
    {"id":"error_invalid_tag","label":"Invalid Player Tag Error Page","file_type":"document","source_file":"C:\\Users\\milo\\Desktop\\rigged-royale-matchup-ml\\.playwright-mcp\\page-2026-06-22T10-00-43-666Z.yml","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Tags only use the alphabet 0 2 8 9 P Y L Q G R J C U V; invalid input shows 'FILE SEALED'."},
