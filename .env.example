# Direct Postgres/Session Pooler URL from Supabase > Connect.
# This is not the service_role key. Use a read-only database user when possible.
SUPABASE_DB_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require

# --- Only needed for `rigged-matchup collect-api` (fetch battles from the CR API) ---

# Clash Royale API token from https://developer.clashroyale.com
# Use the RoyaleAPI proxy base URL so the token works from any IP.
CR_API_TOKEN=
# Optional second token for rate-limit experiments.
CR_API_TOKEN2=
CR_API_BASE_URL=https://proxy.royaleapi.dev/v1

# --- Only needed for `collect-api --upload` (write shards to Supabase Storage) ---
# Project URL, e.g. https://YOURREF.supabase.co  (Storage REST lives under it)
SUPABASE_URL=
# A Supabase secret/service key (sb_secret_... or the legacy service_role JWT).
# Required to create the bucket and upload objects. Keep it out of git.
SUPABASE_SECRET_KEY=

# --- Only needed for `rigged-matchup serve` (HTTP inference for the site) ---
# Path to the trained checkpoint the server loads at startup.
MODEL_CHECKPOINT=artifacts/matchup-model.pt
# Display name reported in /predict responses and /health.
MODEL_NAME=symmetric-matchup
# Optional shared secret. If set, /predict requires a matching X-API-Key header
# (set the same value as the site's PREDICT_API_KEY).
PREDICT_API_KEY=
